# ============================================================
# JETTYтДв тАФ Environment Configuration
# Kupuri MediaтДв ├Ч Akash Engine | Emerald TabletsтДв
# ============================================================
# Copy to .env and fill in at least one AI API key.
# Keys NEVER leave this server. Browser never sees them.
# All secrets managed here тАФ no keys in code.
# ============================================================

# App identity
APP_NAME=JETTYтДв
APP_REGION=Salt Lake City, Utah
APP_TAGLINE=Your thinking, coiled.

# ============================================================
# AI PROVIDERS тАФ fill in at least one
# MODEL_PROVIDER controls the default
# ============================================================
MODEL_PROVIDER=anthropic

# Anthropic Claude тАФ Best reasoning | console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI GPT | platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq тАФ 100% FREE, fastest inference | console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Mistral тАФ Free tier, privacy-first | console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Google Gemini тАФ for Vision Mode | aistudio.google.com
GEMINI_API_KEY=

# ============================================================
# OPTIONAL: INTEGRATIONS (via Composio)
# ============================================================
COMPOSIO_API_KEY=

# ============================================================
# SYSTEM CONFIGURATION
# ============================================================
NOTES_DIR=./notes
RATE_LIMIT_PER_MINUTE=45
MAX_HISTORY=10
DAILY_COST_LIMIT_USD=25
PORT=4700
HOST=0.0.0.0

# ============================================================
# SECRETS MANAGEMENT (Infisical тАФ recommended for production)
# All production keys should live in Infisical vault
# never in this file when committed to version control
# ============================================================
# INFISICAL_API_KEY=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENV=prod
